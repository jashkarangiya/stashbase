{
  "name": "stashbase",
  "version": "0.3.5",
  "description": "Local-first knowledge base desktop app.",
  "author": "liliu-z",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liliu-z/stashbase.git"
  },
  "bugs": {
    "url": "https://github.com/liliu-z/stashbase/issues"
  },
  "homepage": "https://github.com/liliu-z/stashbase#readme",
  "keywords": [
    "knowledge-base",
    "local-first",
    "electron",
    "mcp",
    "milvus",
    "embeddings",
    "rag",
    "semantic-search"
  ],
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n web,srv -c cyan,green \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --config web-src/vite.config.ts",
    "dev:server": "STASHBASE_DEV_VITE=1 tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "mcp": "tsx mcp/server.ts",
    "build:web": "vite build --config web-src/vite.config.ts",
    "build:server": "node scripts/build-server.mjs",
    "build:mcp": "node scripts/build-mcp.mjs",
    "build:python-sidecar": "node scripts/build-python-sidecar.mjs",
    "test:import-folder": "node --import tsx --test server/import-folder.test.ts",
    "postinstall": "node scripts/fix-pty-helper.mjs",
    "build": "pnpm build:web && pnpm build:server && pnpm build:mcp",
    "build:desktop": "pnpm build && pnpm build:python-sidecar",
    "setup:python": "node scripts/setup-python.mjs",
    "prestart": "pnpm build:web",
    "electron": "electron .",
    "dist": "node scripts/package-unsigned.mjs && node scripts/package-unsigned.mjs --win",
    "dist:brew": "node scripts/publish.mjs",
    "pack:mac": "node scripts/package-unsigned.mjs --dir",
    "dist:mac": "node scripts/package-unsigned.mjs",
    "dist:mac:unsigned": "node scripts/package-unsigned.mjs",
    "dist:win": "node scripts/package-unsigned.mjs --win",
    "dist:win:unsigned": "node scripts/package-unsigned.mjs --win"
  },
  "build": {
    "appId": "com.stashbase.app",
    "productName": "StashBase",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "build/icon",
    "electronDist": "node_modules/electron/dist",
    "afterPack": "scripts/after-pack-unsigned.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "package.json",
      "electron/**/*",
      "dist/server/**",
      "dist/mcp/**",
      "web/dist-app/**/*",
      "node_modules/**/*",
      "!dist/pyinstaller/**"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "stashbase_daemon.py",
          "pdf_extract.py",
          "ocr_extract.py",
          "requirements.txt",
          "runtime/**/*",
          "sidecar/**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/@vscode/**/*",
      "node_modules/.pnpm/better-sqlite3*/**/*",
      "node_modules/.pnpm/@vscode+ripgrep*/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": false,
      "title": "StashBase",
      "contents": [
        {
          "x": 120,
          "y": 220,
          "type": "file"
        },
        {
          "x": 420,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 120,
          "y": 80,
          "type": "file",
          "path": "build/dmg-scripts/Fix.sh",
          "name": "Fix.sh"
        },
        {
          "x": 420,
          "y": 80,
          "type": "file",
          "path": "build/dmg-scripts/Read Me.txt",
          "name": "Read Me.txt"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@noble/hashes": "^2.2.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "codemirror": "^6.0.2",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.3",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^39.8.8",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "http-proxy-middleware": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.12"
  }
}
