{
  "name": "stashbase",
  "version": "1.3.0",
  "packageManager": "pnpm@11.5.1",
  "description": "Local-first knowledge base desktop app.",
  "author": {
    "name": "liliu-z",
    "email": "bingwuthu@gmail.com"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liliu-z/stashbase.git"
  },
  "bugs": {
    "url": "https://github.com/liliu-z/stashbase/issues"
  },
  "homepage": "https://github.com/liliu-z/stashbase#readme",
  "keywords": [
    "knowledge-base",
    "local-first",
    "electron",
    "mcp",
    "milvus",
    "embeddings",
    "rag",
    "semantic-search"
  ],
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n web,srv -c cyan,green \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --config web-src/vite.config.ts",
    "dev:server": "STASHBASE_DEV_VITE=1 tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "mcp": "tsx mcp/server.ts",
    "build:web": "vite build --config web-src/vite.config.ts && node scripts/check-renderer-chunks.mjs",
    "build:server": "node scripts/build-server.mjs",
    "build:mcp": "node scripts/build-mcp.mjs",
    "build:python-sidecar": "node scripts/build-python-sidecar.mjs",
    "build:python-extract-sidecar": "node scripts/build-python-sidecar.mjs --with-extract",
    "clean:python-build": "node scripts/clean-python-build.mjs",
    "build": "pnpm build:web && pnpm build:server && pnpm build:mcp",
    "build:desktop": "pnpm build && pnpm build:python-sidecar",
    "setup:python": "node scripts/setup-python.mjs",
    "test:python": "node scripts/test-python.mjs",
    "test:renderer": "node --import tsx --test web-src/src/__tests__/*.test.ts web-src/src/markdown/__tests__/*.test.ts web-src/src/store/__tests__/*.test.ts",
    "test:renderer-chunks": "node scripts/check-renderer-chunks.mjs",
    "test:conversion-scheduler": "node --import tsx --test server/filesystem-path.test.ts server/folder-relative-path.test.ts server/files.test.ts server/keyword-search.test.ts server/index-status.test.ts server/indexer-mfs-path.test.ts server/session-path.test.ts server/conversion-scheduler.test.ts server/conversion-status.test.ts server/conversion.test.ts server/extractor-process.test.ts",
    "test:library-files": "node --import tsx --test server/library-file-mutations.test.ts",
    "test:agent": "node --import tsx --test server/__tests__/agent.test.ts server/__tests__/agent-contract.test.ts server/__tests__/codex-agent.test.ts",
    "test:agent:native": "node --import tsx --test server/__tests__/agent-native-smoke.test.ts",
    "test:mcp": "node --import tsx --test server/__tests__/mcp-http-settings.test.ts server/__tests__/mcp-http-service.test.ts server/__tests__/mcp-http-transport.test.ts server/__tests__/shutdown-cleanup.test.ts",
    "test:release-gate": "node --test scripts/require-green-ci.test.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web-src/tsconfig.json",
    "check": "pnpm test:python && pnpm test:release-gate && pnpm test:renderer && pnpm test:conversion-scheduler && pnpm test:library-files && pnpm test:agent && pnpm test:mcp && pnpm typecheck && pnpm build",
    "prestart": "pnpm build:web",
    "electron": "electron .",
    "package:mac": "node scripts/package-unsigned.mjs",
    "package:mac:dir": "node scripts/package-unsigned.mjs --dir",
    "package:win": "node scripts/package-unsigned.mjs --win",
    "package:linux": "node scripts/package-unsigned.mjs --linux",
    "dist": "pnpm package:mac",
    "dist:all": "pnpm package:mac && pnpm package:win && pnpm package:linux",
    "dist:brew": "node scripts/publish.mjs",
    "smoke:packaged-server": "node scripts/smoke-packaged-server.mjs",
    "release:verify:mac": "node scripts/release-verify-mac.mjs",
    "pack:mac": "pnpm package:mac:dir",
    "dist:mac": "pnpm package:mac",
    "dist:win": "pnpm package:win",
    "dist:linux": "pnpm package:linux"
  },
  "build": {
    "appId": "com.stashbase.app",
    "productName": "StashBase",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "build/icon",
    "electronDist": "node_modules/electron/dist",
    "afterPack": "scripts/after-pack-unsigned.cjs",
    "directories": {
      "output": "release.nosync"
    },
    "files": [
      "package.json",
      "electron/**/*",
      "dist/server/**",
      "dist/mcp/**",
      "web/dist-app/**/*",
      "node_modules/**/*",
      "!dist/pyinstaller/**"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "stashbase_daemon.py",
          "pdf_extract.py",
          "ocr_extract.py",
          "requirements.txt",
          "runtime/**/*"
        ]
      },
      {
        "from": "python/sidecar.nosync",
        "to": "python/sidecar"
      },
      {
        "from": "assets/builtin-library",
        "to": "assets/builtin-library"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/@vscode/**/*",
      "node_modules/@anthropic-ai/claude-agent-sdk*/**/*",
      "node_modules/.pnpm/better-sqlite3*/**/*",
      "node_modules/.pnpm/@vscode+ripgrep*/**/*",
      "node_modules/.pnpm/@anthropic-ai+claude-agent-sdk*/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "sign": false,
      "title": "StashBase",
      "contents": [
        {
          "x": 120,
          "y": 220,
          "type": "file"
        },
        {
          "x": 420,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 120,
          "y": 80,
          "type": "file",
          "path": "build/dmg-scripts/Fix.sh",
          "name": "Fix.sh"
        },
        {
          "x": 420,
          "y": 80,
          "type": "file",
          "path": "build/dmg-scripts/Read Me.txt",
          "name": "Read Me.txt"
        },
        {
          "x": 40,
          "y": 40,
          "type": "file",
          "path": "scripts/sign-macos-app.sh",
          "name": ".sign-macos-app.sh"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "category": "Office",
      "target": [
        "deb"
      ],
      "icon": "build/icons"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libnss3",
        "libatk1.0-0",
        "libatk-bridge2.0-0",
        "libgdk-pixbuf2.0-0",
        "libgtk-3-0",
        "libx11-xcb1",
        "libxcb-dri3-0",
        "libxtst6",
        "libasound2"
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.161",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@noble/hashes": "^2.2.0",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "codemirror": "^6.0.2",
    "express": "^4.21.2",
    "github-slugger": "^2.0.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "marked-alert": "2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.4",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.6",
    "ws": "^8.20.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^39.8.8",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "http-proxy-middleware": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.12"
  },
  "optionalDependencies": {
    "@vscode/ripgrep-darwin-arm64": "1.18.0",
    "@vscode/ripgrep-linux-x64": "1.18.0",
    "@vscode/ripgrep-win32-x64": "1.18.0"
  }
}
